[Unit]
Description=EHC vLLM Server
After=network.target

[Service]
Type=simple
User=phungkien
WorkingDirectory=/home/phungkien/EHC_HELPDESK/ehc-helpdesk
Environment="PATH=/home/phungkien/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
ExecStart=/usr/bin/python3 -m vllm.entrypoints.openai.api_server --model Qwen/Qwen2.5-7B-Instruct --host 0.0.0.0 --port 8000 --tensor-parallel-size 2 --load-format safetensors --dtype half --gpu-memory-utilization 0.90
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
